using Avalonia.Controls;
using Avalonia.Interactivity;

namespace GovAdmin.UI;

public partial class MainWindow : Window
{
    public MainWindow()
    {
        InitializeComponent();
    }

    private void GenerateButton_Click(object? sender, RoutedEventArgs e)
    {
        var title = this.FindControl<TextBlock>("TicketTitle");
        if (title != null) title.Text = "Ticket: GA-" + System.Guid.NewGuid().ToString().Substring(0, 8);
    }

    private void ExecuteButton_Click(object? sender, RoutedEventArgs e)
    {
        var input = this.FindControl<TextBox>("ScriptInput");
        var output = this.FindControl<TextBlock>("OutputText");
        
        if (output != null && input != null) 
            output.Text = "> Executing: " + input.Text;
    }
}
