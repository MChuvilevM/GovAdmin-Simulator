<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GovAdmin.UI.MainWindow"
        Title="GovAdmin Simulator" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock Text="Enterprise Terminal v4.0" FontWeight="Bold" FontSize="18"/>
        
        <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,10">
            <StackPanel>
                <TextBlock Name="TicketTitle" Text="Waiting for ticket..." FontWeight="SemiBold"/>
                <Button Content="Generate New Ticket" Click="GenerateButton_Click" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TextBox Name="ScriptInput" Height="150" AcceptsReturn="True" FontFamily="Consolas" Margin="0,10"/>
        <Button Content="Execute Script" Click="ExecuteButton_Click"/>
        <TextBlock Name="OutputText" Margin="0,10" Foreground="LightGreen"/>
    </StackPanel>
</Window>
