    <PackageReference Include="Avalonia.Diagnostics" Version="11.2.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GovAdmin.Engine\GovAdmin.Engine.csproj" />
    <ProjectReference Include="..\GovAdmin.Core\GovAdmin.Core.csproj" />
  </ItemGroup>
</Project>
